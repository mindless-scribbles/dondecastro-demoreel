---
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

interface Props {
  title?: string;
  description?: string;
  frontmatter?: { title?: string; description?: string };
}

const { frontmatter, title, description } = Astro.props;
const pageTitle = frontmatter?.title ?? title;
const pageDescription = frontmatter?.description ?? description;

const expertiseNav = [
  { label: "Home", href: "/" },
  { label: "Journal", href: "/journal" },
  { label: "Contact", href: "/contact" },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="page-frame">
    <div class="page-frame-inner">
      <SiteHeader navItems={expertiseNav} />
      <div class="download-btn-wrap">
        <a class="download-btn" href="/DonDeCastro-Resume.pdf" download>
          <svg class="download-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          <span class="download-label">Download Resume</span>
        </a>
      </div>
      <article class="prose">
        <slot />
      </article>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* Hide the viewport-fixed frame on markdown-layout pages so our
     content-height border is the only one. */
  body:has(.page-frame) .frame {
    display: none;
  }
</style>

<style>
  .page-frame {
    position: relative;
    z-index: 10;
    margin: 1.5rem;
    border: 1px solid rgba(244, 244, 245, 0.1);
    min-height: calc(100vh - 3rem);
  }

  .page-frame-inner {
    padding: 1.5rem;
  }

  @media (max-width: 768px) {
    .page-frame {
      margin: 0.75rem;
      min-height: calc(100vh - 1.5rem);
    }

    .page-frame-inner {
      padding: 1rem;
    }
  }

  .download-btn-wrap {
    max-width: 68ch;
    margin: 0 auto;
    padding: 2rem 1rem 0;
    display: flex;
    justify-content: flex-end;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    border: 1px solid rgba(244, 244, 245, 0.3);
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    text-decoration: none;
    transition: border-color 0.3s ease, color 0.3s ease;
    cursor: pointer;
  }

  .download-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .download-icon {
    width: 0.9rem;
    height: 0.9rem;
  }

  .prose {
    max-width: 68ch;
    margin: 0 auto;
    padding: 3rem 1rem 4rem;
  }

  @media (max-width: 768px) {
    .prose {
      padding: 2rem 0.5rem 3rem;
    }
  }

  .prose :global(h1) {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 1.25rem;
    letter-spacing: 0.05em;
    line-height: 1.2;
    margin: 3rem 0 1.25rem;
    color: var(--color-text);
  }

  .prose :global(h3) {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin: 2rem 0 0.25rem;
    color: var(--color-accent);
  }

  .prose :global(p) {
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0 0 1rem;
    color: rgba(244, 244, 245, 0.85);
  }

  .prose :global(a) {
    color: rgba(82, 82, 91, 0.8);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .prose :global(a:hover) {
    color: rgba(255, 51, 0, 0.55);
  }

  .prose :global(ul) {
    margin: 0 0 1rem;
    padding-left: 1.25rem;
    list-style: none;
  }

  .prose :global(li) {
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0 0 0.4rem;
    color: rgba(244, 244, 245, 0.85);
    position: relative;
  }

  .prose :global(li::before) {
    content: "›";
    position: absolute;
    left: -1.25rem;
    color: var(--color-accent);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(244, 244, 245, 0.1);
    margin: 3rem 0;
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: 700;
  }

  .prose :global(em) {
    font-style: italic;
    color: rgba(244, 244, 245, 0.9);
  }
</style>
