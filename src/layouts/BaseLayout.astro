---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Don De Castro — Technical Animator & Motion Edit Supervisor",
  description = "Portfolio of Don De Castro — Technical Animator and Motion Edit Supervisor. Feature film, AAA games, virtual production.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Space+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="font-mono bg-[var(--color-bg)] text-[var(--color-text)]">
    <div class="noise" aria-hidden="true"></div>
    <div class="frame" aria-hidden="true"></div>
    <slot />
  </body>
</html>

<style>
  .noise {
    position: fixed;
    inset: 0;
    z-index: 3;
    opacity: 0.12;
    pointer-events: none;
    mix-blend-mode: screen;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .frame {
    position: fixed;
    inset: 24px;
    border: 1px solid rgba(244, 244, 245, 0.1);
    z-index: 4;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .frame {
      inset: 12px;
    }
  }

  @media (min-width: 1025px) {
    .frame {
      inset: 1.5rem 1.5rem 10.5rem 1.5rem;
    }
  }
</style>
