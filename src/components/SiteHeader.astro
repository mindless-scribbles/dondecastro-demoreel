---
interface Props {
  navItems?: { label: string; href: string }[];
  sticky?: boolean;
}

const defaultNav = [
  { label: "Expertise", href: "/expertise" },
  { label: "Journal", href: "/journal" },
  { label: "Contact", href: "/contact" },
];

const { navItems = defaultNav, sticky = false } = Astro.props;
const hasMiddle = Astro.slots.has("middle");
---

<header
  class:list={[
    "grid grid-cols-[1fr_auto_1fr] items-start w-full relative z-30 px-3 py-2 md:px-4 md:py-3",
    { sticky: sticky },
  ]}
>
  <a href="/" class="brand col-start-1 justify-self-start" aria-label="MS — Creative Agency, home">
    <span class="brand-letters">
      <span class="brand-m">M</span>
      <span class="brand-s">S</span>
    </span>
    <span class="brand-sub">Creative Agency</span>
  </a>

  {
    hasMiddle && (
      <div class="middle col-start-2 justify-self-center">
        <slot name="middle" />
      </div>
    )
  }

  <nav class="nav col-start-3 justify-self-end">
    {
      navItems.map((item) => (
        <a href={item.href} class="nav-link">
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<style>
  header {
    padding-top: 0.75rem;
  }

  header.sticky {
    position: sticky;
    top: 0;
    z-index: 20;
    background-color: var(--color-bg);
    border-bottom: 1px solid rgba(244, 244, 245, 0.1);
  }

  .middle {
    align-self: center;
  }

  @media (min-width: 768px) {
    header {
      padding-top: 1rem;
    }
  }

  @media (max-width: 1024px) and (orientation: landscape) {
    header {
      padding-top: 0.5rem;
    }
  }

  @media (min-width: 768px) and (max-width: 1024px) and (orientation: landscape) {
    header {
      padding-top: 0.75rem;
    }
  }

  .brand {
    color: rgba(82, 82, 91, 0.8);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1;
  }

  .brand-letters {
    display: flex;
    align-items: baseline;
    line-height: 1;
  }

  .brand-m {
    font-family: var(--font-serif);
    font-size: 1.98rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    color: rgba(82, 82, 91, 0.8);
  }

  .brand-s {
    font-family: var(--font-serif);
    font-size: 2.16rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.02em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(82, 82, 91, 0.8);
  }

  .brand-sub {
    font-family: var(--font-mono);
    font-size: 0.585rem;
    font-weight: 400;
    color: rgba(255, 51, 0, 0.55);
    margin-top: -2px;
  }

  .nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-align: right;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.675rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(82, 82, 91, 0.8);
    text-decoration: none;
    display: inline-block;
    padding-bottom: 2px;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: rgba(255, 51, 0, 0.55);
  }

  @media (max-width: 1024px) {
    .brand-m {
      font-size: 1.62rem;
    }

    .brand-s {
      font-size: 1.8rem;
    }

    .brand-sub {
      font-size: 0.54rem;
    }

    .nav-link {
      font-size: 0.585rem;
    }
  }

  @media (max-width: 768px) {
    .nav {
      flex-direction: row;
      gap: 16px;
    }

    .nav-link {
      font-size: 0.54rem;
    }
  }

  @media (max-width: 768px) and (orientation: portrait) {
    .brand-m {
      font-size: 1.35rem;
    }

    .brand-s {
      font-size: 1.53rem;
    }

    .brand-sub {
      font-size: 0.495rem;
      margin-top: -1px;
    }
  }
</style>
