---
interface Props {
  navItems?: { label: string; href: string }[];
}

const defaultNav = [
  { label: "Expertise", href: "/expertise" },
  { label: "Journal", href: "/blog" },
  { label: "Contact", href: "/contact" },
];

const { navItems = defaultNav } = Astro.props;
---

<header class="flex justify-between items-start w-full relative z-30 px-3 py-2 md:px-4 md:py-3">
  <a href="/" class="brand" aria-label="MS — Creative Agency, home">
    <span class="brand-letters">
      <span class="brand-m">M</span>
      <span class="brand-s">S</span>
    </span>
    <span class="brand-sub">Creative Agency</span>
  </a>

  <nav class="nav">
    {
      navItems.map((item) => (
        <a href={item.href} class="nav-link">
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<style>
  header {
    padding-top: 0.75rem;
  }

  @media (min-width: 768px) {
    header {
      padding-top: 1rem;
    }
  }

  @media (max-width: 1024px) and (orientation: landscape) {
    header {
      padding-top: 0.5rem;
    }
  }

  @media (min-width: 768px) and (max-width: 1024px) and (orientation: landscape) {
    header {
      padding-top: 0.75rem;
    }
  }

  .brand {
    color: rgba(82, 82, 91, 0.8);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1;
  }

  .brand-letters {
    display: flex;
    align-items: baseline;
    line-height: 1;
  }

  .brand-m {
    font-family: var(--font-serif);
    font-size: 1.98rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    color: rgba(82, 82, 91, 0.8);
  }

  .brand-s {
    font-family: var(--font-serif);
    font-size: 2.16rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.02em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(82, 82, 91, 0.8);
  }

  .brand-sub {
    font-family: var(--font-mono);
    font-size: 0.585rem;
    font-weight: 400;
    color: rgba(255, 51, 0, 0.55);
    margin-top: -2px;
  }

  .nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-align: right;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.675rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(82, 82, 91, 0.8);
    text-decoration: none;
    position: relative;
    display: inline-block;
    padding-bottom: 2px;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    right: 0;
    width: 0%;
    height: 1px;
    background-color: var(--color-accent);
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav-link:hover::after {
    width: 100%;
    left: 0;
    right: auto;
  }

  @media (max-width: 1024px) {
    .brand-m {
      font-size: 1.62rem;
    }

    .brand-s {
      font-size: 1.8rem;
    }

    .brand-sub {
      font-size: 0.54rem;
    }

    .nav-link {
      font-size: 0.585rem;
    }
  }

  @media (max-width: 768px) {
    .nav {
      flex-direction: row;
      gap: 16px;
    }

    .nav-link {
      font-size: 0.54rem;
    }
  }

  @media (max-width: 768px) and (orientation: portrait) {
    .brand-m {
      font-size: 1.35rem;
    }

    .brand-s {
      font-size: 1.53rem;
    }

    .brand-sub {
      font-size: 0.495rem;
      margin-top: -1px;
    }
  }
</style>
