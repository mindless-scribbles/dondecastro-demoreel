---
// Hero block shown on the homepage. Static — no loader, no canvas.
---

<section class="flex flex-col items-center w-full relative z-20 text-center mb-[4.5rem] md:mb-[9rem]">
  <div class="hero-content">
    <h1 class="hero-title">Don De Castro</h1>
    <p class="tagline">
      Technical Animator &amp; Motion Edit Supervisor.<br />
      Feature film, AAA games, virtual production.
    </p>
  </div>
  <button class="play-btn" type="button" aria-label="Play reel">
    <span class="btn-fill" aria-hidden="true"></span>
    <span class="play-label">Play Reel</span>
    <svg class="play-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M8 5v14l11-7z"></path>
    </svg>
  </button>
</section>

<style>
  .hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
    font-size: 6.3vw;
    white-space: nowrap;
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 0.675rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.6;
    margin: 0.75rem 0 0;
    white-space: nowrap;
  }

  .play-btn {
    display: none;
    position: relative;
    align-items: center;
    gap: 1rem;
    border: 1px solid rgba(244, 244, 245, 0.3);
    padding: 1rem 2.25rem;
    overflow: hidden;
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
    transition: border-color 0.3s ease;
    isolation: isolate;
  }

  .play-btn:hover {
    border-color: var(--color-accent);
  }

  .btn-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0;
    background: var(--color-accent);
    z-index: -1;
    transition: width 0.3s ease;
  }

  .play-btn:hover .btn-fill {
    width: 100%;
  }

  .play-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
  }

  .play-icon {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 6.75vw;
    }

    .tagline {
      font-size: 0.585rem;
      letter-spacing: 0.1em;
    }
  }

  @media (max-width: 1024px) and (orientation: landscape) {
    .hero-content {
      display: none;
    }

    .play-btn {
      display: inline-flex;
    }
  }

  @media (max-width: 768px) and (orientation: portrait) {
    .hero-title {
      font-size: 6.16vw;
    }

    .tagline {
      font-size: 0.54rem;
      letter-spacing: 0.1em;
    }
  }
</style>
