---
// Hero block shown on the homepage. Static — no loader, no canvas.
---

<section class="flex flex-col items-center w-full relative z-20 text-center mb-[4.5rem] md:mb-[9rem]">
  <div class="hero-content">
    <h1 class="hero-title">Don De Castro</h1>
    <p class="tagline">
      Technical Animator &amp; Motion Edit Supervisor.<br />
      Feature film, AAA games, virtual production.
    </p>
  </div>
  <div class="play-actions">
    <button class="play-btn" type="button" aria-label="Play reel">
      <span class="play-label">Play Reel</span>
      <svg class="play-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M8 5v14l11-7z"></path>
      </svg>
    </button>
    <div class="sub-actions">
      <a class="sub-btn" href="https://youtu.be/_6fQY8wwXQs" target="_blank" rel="noopener noreferrer">
        <span class="btn-fill" aria-hidden="true"></span>
        <span class="sub-label">Tech Anim</span>
      </a>
      <a class="sub-btn" href="https://youtu.be/4ca-ywgyVdE" target="_blank" rel="noopener noreferrer">
        <span class="btn-fill" aria-hidden="true"></span>
        <span class="sub-label">Mocap / Anim</span>
      </a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>(".play-actions").forEach((wrapper) => {
    const playBtn = wrapper.querySelector<HTMLButtonElement>(".play-btn");
    if (!playBtn) return;

    playBtn.addEventListener("click", (e) => {
      if (window.matchMedia("(hover: none)").matches) {
        e.preventDefault();
        wrapper.classList.toggle("open");
      }
    });

    document.addEventListener("click", (e) => {
      if (!wrapper.contains(e.target as Node)) {
        wrapper.classList.remove("open");
      }
    });
  });
</script>

<style>
  .hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
    font-size: 6.3vw;
    white-space: nowrap;
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 0.675rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.6;
    margin: 0.75rem 0 0;
    white-space: nowrap;
  }

  .play-actions {
    display: none;
    position: relative;
    flex-direction: column;
    align-items: center;
  }

  .play-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    border: 1px solid rgba(244, 244, 245, 0.3);
    padding: 1rem 2.25rem;
    overflow: hidden;
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
    transition: border-color 0.3s ease;
    isolation: isolate;
  }

  .play-btn:hover {
    border-color: var(--color-accent);
  }

  .sub-actions {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 0.75rem;
    display: flex;
    gap: 0.75rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    pointer-events: none;
  }

  .play-actions.open .sub-actions,
  .play-actions:hover .sub-actions {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .sub-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(244, 244, 245, 0.3);
    padding: 0.6rem 1.25rem;
    overflow: hidden;
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
    transition: border-color 0.3s ease;
    isolation: isolate;
    white-space: nowrap;
  }

  .sub-btn:hover {
    border-color: var(--color-accent);
  }

  .sub-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  .btn-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0;
    background: var(--color-accent);
    z-index: -1;
    transition: width 0.3s ease;
  }

  .sub-btn:hover .btn-fill {
    width: 100%;
  }

  .play-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
  }

  .play-icon {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 6.75vw;
    }

    .tagline {
      font-size: 0.585rem;
      letter-spacing: 0.1em;
    }
  }

  @media (max-width: 1024px) and (orientation: landscape) {
    .hero-content {
      display: none;
    }

    .play-actions {
      display: inline-flex;
      position: fixed;
      left: 50%;
      transform: translateX(-50%);
      bottom: calc(10vh + 5.18vw + 7.625rem);
    }
  }

  @media (min-width: 768px) and (max-width: 1024px) and (orientation: landscape) {
    .play-actions {
      bottom: calc(10vh + 5.18vw + 8.875rem);
    }
  }

  @media (hover: none) {
    .play-actions:hover .sub-actions {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .play-actions.open .sub-actions {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
  }

  @media (max-width: 768px) and (orientation: portrait) {
    .hero-title {
      font-size: 6.16vw;
    }

    .tagline {
      font-size: 0.54rem;
      letter-spacing: 0.1em;
    }
  }
</style>
