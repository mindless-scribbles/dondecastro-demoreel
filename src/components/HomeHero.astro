---
// Hero block shown on the homepage. Static — no loader, no canvas.
---

<section class="flex justify-between items-end w-full">
  <div class="flex flex-col gap-8 max-w-5xl">
    <h1 class="hero-title">
      <span class="word word-primary">Don</span>
      <span class="word word-secondary"
        ><span class="sub-de">De</span> <span class="sub-castro">Castro</span></span
      >
    </h1>

    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mt-4">
      <p class="tagline">
        Technical Animator &amp; Motion Edit Supervisor. Feature film, AAA
        games, virtual production.
      </p>
      <a href="/reel" class="cta">View Reel</a>
    </div>
  </div>
</section>

<style>
  .hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.8;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
  }

  .hero-title .word {
    display: block;
    white-space: nowrap;
  }

  .hero-title .word-primary {
    font-size: 7.2vw;
    margin-left: 5vw;
  }

  .hero-title .word-secondary {
    font-size: 8.1vw;
    margin-left: 12vw;
    margin-top: -0.5vw;
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    max-width: 22rem;
    line-height: 1.6;
    margin: 0;
  }

  .cta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    border: 1px solid var(--color-muted);
    padding: 1rem 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    transition:
      color 0.3s ease,
      border-color 0.3s ease,
      background-color 0.3s ease;
  }

  .cta:hover {
    color: var(--color-bg);
    background-color: var(--color-accent);
    border-color: var(--color-accent);
  }

  @media (max-width: 1024px) {
    .tagline {
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      max-width: 16rem;
    }

    .cta {
      padding: 0.75rem 1.25rem;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
    }
  }

  @media (max-width: 1024px) and (orientation: landscape) {
    .hero-title .word-primary {
      font-size: 7.25vw;
      margin-left: 4vw;
    }

    .hero-title .word-secondary {
      font-size: 7.95vw;
      margin-left: 9vw;
      margin-top: -0.5vw;
    }
  }

  @media (max-width: 768px) and (orientation: portrait) {
    .hero-title .word-primary {
      font-size: 7.3vw;
      margin-left: 4vw;
    }

    .hero-title .word-secondary {
      font-size: 7.9vw;
      margin-left: 6vw;
      margin-top: -0.5vw;
    }

    .tagline {
      font-size: 0.6rem;
      max-width: calc(100vw - 3rem);
    }

    .cta {
      padding: 0.65rem 1rem;
      font-size: 0.55rem;
      align-self: center;
    }
  }
</style>
